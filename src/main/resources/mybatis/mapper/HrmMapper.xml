<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    테이블 구조
    ┌──────────────────────────────────────────────────────┐
    │ employee1 (인증)                                      │
    │   empId(PK), password, levelCode, enabled,           │
    │   regDate, updateDate, lastLoginDate,                │
    │   loginFailureCount, empStatusCode                   │
    ├──────────────────────────────────────────────────────┤
    │ employee2 (인적, FK→employee1.empId)                  │
    │   empId(PK,FK), name, birth, profilePhoto, tel,      │
    │   zip, addr1, addr2, email, ipAddr,                  │
    │   hireDate, deptCode, gradeCode, regEmpId, regDate   │
    ├──────────────────────────────────────────────────────┤
    │ project                                              │
    │   projectId(PK), title, description,                 │
    │   startDate, endDate, createdDate, status, Progress  │
    ├──────────────────────────────────────────────────────┤
    │ empProject (사원-프로젝트 연결)                        │
    │   empProjId(PK), empId(FK→employee1),                │
    │   predecessor, projectId(FK→project),                │
    │   startDate, endDate, isPmo(CHAR(1): Y/N)            │
    └──────────────────────────────────────────────────────┘

    empStatusCode (CHAR(1))
      ES01 = 재직(EMPLOYED)
      ES02 = 휴직(LEAVE)
      ES03 = 퇴직(RESIGNED)
      ES04 = 계약만료(RESIGNED)

    isPmo (CHAR(1))
      Y = PMO 여부 Y
      N = PMO 여부 N
-->
<mapper namespace="com.mvc.app.mapper.HrmMapper">

    <!-- ════════════════════════════════════════
         ResultMap — employee1 + employee2 JOIN
    ════════════════════════════════════════ -->
    <resultMap id="employeeResultMap" type="com.mvc.app.domain.dto.HrmDto">
        <!-- employee1 -->
        <id     property="empId"              column="empId"/>
        <result property="password"           column="password"/>
        <result property="levelCode"          column="levelCode"/>
        <result property="enabled"            column="enabled"/>
        <result property="empStatusCode"      column="empStatusCode"/>
        <result property="lastLoginDate"      column="lastLoginDate"/>
        <result property="loginFailureCount"  column="loginFailureCount"/>
        <result property="e1RegDate"          column="e1RegDate"/>
        <result property="updateDate"         column="updateDate"/>
        <!-- employee2 -->
        <result property="name"               column="name"/>
        <result property="birth"              column="birth"/>
        <result property="profilePhoto"       column="profilePhoto"/>
        <result property="tel"                column="tel"/>
        <result property="zip"                column="zip"/>
        <result property="addr1"              column="addr1"/>
        <result property="addr2"              column="addr2"/>
        <result property="email"              column="email"/>
        <result property="ipAddr"             column="ipAddr"/>
        <result property="hireDate"           column="hireDate"/>
        <result property="deptCode"           column="deptCode"/>
        <result property="gradeCode"          column="gradeCode"/>
        <!-- 화면 표시용 코드명 (commoncode JOIN) -->
        <result property="deptName"           column="deptName"/>
        <result property="gradeName"          column="gradeName"/>
        <result property="regEmpId"           column="regEmpId"/>
        <result property="e2RegDate"          column="e2RegDate"/>
        <!-- 추가 -->
        <result property="projectNames"       column="projectNames"/>
        <result property="authorityCode" column="authorityCode"/>
    	<result property="authorityName" column="authorityName"/>
    </resultMap>

    <!-- ════════════════════════════════════════
         공통 검색 조건
         searchParams 키:
           name, empNo, project(프로젝트명 LIKE),
           empStatusCode, levelCode,
           pmoY(isPmo='Y'), pmoN(isPmo='N')
    ════════════════════════════════════════ -->
    <sql id="searchWhere">
        <where>
            <if test="name != null and name != ''">
                AND e2.name LIKE '%' || #{name} || '%'
            </if>
            <if test="empNo != null and empNo != ''">
                AND e1.empId LIKE '%' || #{empNo} || '%'
            </if>
            <if test="empStatusCode != null and empStatusCode != ''">
                AND e1.empStatusCode = #{empStatusCode}
            </if>
            <if test="levelCode != null">
                AND e1.levelCode = #{levelCode}
            </if>
            <!-- 권한코드 검색 : employeeAuthority JOIN -->
            <if test="authorityCode != null and authorityCode != ''">
                AND EXISTS (
                    SELECT 1 FROM employeeAuthority ea
                    WHERE  ea.empId    = e1.empId
                    AND    ea.authority = #{authorityCode}
                )
            </if>
            <!-- 부서코드 검색 -->
            <if test="deptCode != null and deptCode != ''">
                AND e2.deptCode = #{deptCode}
            </if>
            <!-- 직급코드 검색 -->
            <if test="gradeCode != null and gradeCode != ''">
                AND e2.gradeCode = #{gradeCode}
            </if>
            <!-- 프로젝트명 검색 : empProject → project JOIN -->
            <if test="project != null and project != ''">
                AND EXISTS (
                    SELECT 1
                    FROM   empProject ep
                    JOIN   project    pj ON ep.projectId = pj.projectId
                    WHERE  ep.empId   = e1.empId
                    AND    pj.title  LIKE '%' || #{project} || '%'
                )
            </if>
            <!-- PMO Y 검색 -->
            <if test="pmoY == true">
                AND EXISTS (
                    SELECT 1
                    FROM   empProject ep
                    WHERE  ep.empId = e1.empId
                    AND    ep.isPmo = 'Y'
                )
            </if>
            <!-- PMO N 검색 (PMO가 아예 없거나 전부 N인 사원) -->
            <if test="pmoN == true">
                AND NOT EXISTS (
                    SELECT 1
                    FROM   empProject ep
                    WHERE  ep.empId = e1.empId
                    AND    ep.isPmo = 'Y'
                )
            </if>
            	AND e1.drawCode is null
        </where>
    </sql>

    <!-- ════════════════════════════════════════
         공통 SELECT 컬럼 목록
    ════════════════════════════════════════ -->
    <sql id="selectColumns">
        e1.empId,
        e1.password,
        e1.levelCode,
        e1.enabled,
        e1.empStatusCode,
        TO_CHAR(e1.lastLoginDate, 'YYYY-MM-DD HH24:MI') AS lastLoginDate,
        e1.loginFailureCount,
        TO_CHAR(e1.regDate,    'YYYY-MM-DD') AS e1RegDate,
        TO_CHAR(e1.updateDate, 'YYYY-MM-DD') AS updateDate,
        e2.name,
        TO_CHAR(e2.birth,    'YYYY-MM-DD') AS birth,
        e2.profilePhoto,
        e2.tel,
        e2.zip,
        e2.addr1,
        e2.addr2,
        e2.email,
        e2.ipAddr,
        ea.authority AS authorityCode,
        TO_CHAR(e2.hireDate, 'YYYY-MM-DD') AS hireDate,
        e2.deptCode,
        e2.gradeCode,
        (SELECT cc.codeName FROM COMMONCODE cc
         WHERE cc.codeGroup = 'DEPT' AND cc.code = e2.deptCode) AS deptName,
        (SELECT cc.codeName FROM COMMONCODE cc
         WHERE cc.codeGroup = 'RANK' AND cc.code = e2.gradeCode) AS gradeName,
        (SELECT cc.codeName FROM COMMONCODE cc
         WHERE cc.codeGroup = 'AUTHORITY' AND cc.code = ea.authority) AS authorityName,
        (SELECT cc.codeName FROM COMMONCODE cc
         WHERE cc.codeGroup = 'EMPSTATUS' AND cc.code = e1.empstatuscode) AS empStatusName,
        e2.regEmpId,
        TO_CHAR(e2.regDate,  'YYYY-MM-DD') AS e2RegDate,
        (
            SELECT LISTAGG(pj.title, ', ')
                   WITHIN GROUP (ORDER BY pj.title)
            FROM   empProject ep
            JOIN   project    pj ON ep.projectId = pj.projectId
            WHERE  ep.empId = e1.empId
        ) AS projectNames
    </sql>

    <!-- ════════════════════════════════════════
         [1] 전체 건수
    ════════════════════════════════════════ -->
    <select id="dataCount" parameterType="map" resultType="int">
        SELECT COUNT(*)
        FROM   employee1 e1
        JOIN   employee2 e2 ON e1.empId = e2.empId
        <include refid="searchWhere"/>
    </select>

    <!-- ════════════════════════════════════════
         [2] 목록 조회 (페이징 + 정렬)
         Oracle : OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
    ════════════════════════════════════════ -->
    <select id="listEmployee" parameterType="map" resultMap="employeeResultMap">
        SELECT
            <include refid="selectColumns"/>
        FROM   employee1 e1
        JOIN   employee2 e2 ON e1.empId = e2.empId
        JOIN   employeeAuthority ea ON e1.empid = ea.empid
        <include refid="searchWhere"/>
        <choose>
            <when test="sortCol != null and sortCol != ''">
                <choose>
                    <when test="sortCol == 'name'">    ORDER BY e2.name       </when>
                    <when test="sortCol == 'empNo'">   ORDER BY e1.empId      </when>
                    <when test="sortCol == 'dept'">    ORDER BY e2.deptCode   </when>
                    <when test="sortCol == 'rank'">    ORDER BY e2.gradeCode  </when>
                    <when test="sortCol == 'status'">  ORDER BY e1.empStatusCode </when>
                    <otherwise>                        ORDER BY e1.empId      </otherwise>
                </choose>
                <choose>
                    <when test="sortDir == 'DESC'"> DESC </when>
                    <otherwise>                     ASC  </otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY e1.empId DESC
            </otherwise>
        </choose>
        OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
    </select>

    <!-- ════════════════════════════════════════
         [3] 단건 조회
    ════════════════════════════════════════ -->
    <select id="findById" parameterType="string" resultMap="employeeResultMap">
        SELECT
            <include refid="selectColumns"/>
        FROM   employee1 e1
        JOIN   employee2 e2 ON e1.empId = e2.empId
        WHERE  e1.empId = #{empId}
    </select>

    <!-- ════════════════════════════════════════
         [4] 사원번호 중복 체크 (employee1 기준)
    ════════════════════════════════════════ -->
    <select id="findByEmpId" parameterType="string" resultMap="employeeResultMap">
        SELECT empId
        FROM   employee1
        WHERE  empId = #{empId}
    </select>

    <!-- ════════════════════════════════════════
         [4-1] 가장 큰 사원번호 조회 (자동채번용)
               empId 는 VARCHAR2(11) — 숫자 형태로 저장된다고 가정
               MAX(TO_NUMBER(empId)) 로 최댓값을 구한 뒤 +1 반환
    ════════════════════════════════════════ -->
    <select id="findMaxEmpId" resultType="string">
        SELECT NVL(MAX(TO_NUMBER(empId DEFAULT 0 ON CONVERSION ERROR)), 0)
		FROM   employee1
    </select>

    <!-- ════════════════════════════════════════
         [5-1] 직원 등록 — employee1 먼저 INSERT
               (employee2 가 employee1 을 FK 참조하므로)
    ════════════════════════════════════════ -->
    <insert id="insertEmployee1" parameterType="com.mvc.app.domain.dto.HrmDto">
        INSERT INTO employee1
            (empId, password, levelCode, enabled, empStatusCode, regDate, updateDate)
        VALUES
            (#{empId}, #{password},
             #{levelCode,   jdbcType=NUMERIC},
             #{enabled,     jdbcType=NUMERIC},
             #{empStatusCode, jdbcType=CHAR},
             SYSDATE, SYSDATE)
    </insert>

    <!-- ════════════════════════════════════════
         [5-2] 직원 등록 — employee2 INSERT
    ════════════════════════════════════════ -->
    <insert id="insertEmployee2" parameterType="com.mvc.app.domain.dto.HrmDto">
        INSERT INTO employee2
            (empId, name, birth, profilePhoto, tel,
             zip, addr1, addr2, email,
             hireDate, deptCode, gradeCode, regEmpId, regDate)
        VALUES
            (#{empId}, #{name},
             #{birth,        jdbcType=DATE},
             #{profilePhoto, jdbcType=VARCHAR},
             #{tel,          jdbcType=VARCHAR},
             #{zip,          jdbcType=VARCHAR},
             #{addr1,        jdbcType=VARCHAR},
             #{addr2,        jdbcType=VARCHAR},
             #{email,        jdbcType=VARCHAR},
             SYSDATE,
             #{deptCode,     jdbcType=VARCHAR},
             #{gradeCode,    jdbcType=VARCHAR},
             #{regEmpId,     jdbcType=VARCHAR},
             SYSDATE)
    </insert>
    
    <!-- ════════════════════════════════════════
         [5-3] 직원 권한 등록 — employeeAuthority INSERT
    ════════════════════════════════════════ -->
    <insert id="insertAuthority" parameterType="com.mvc.app.domain.dto.HrmDto">
        INSERT INTO employeeAuthority
            (
            empId, 
            authority
            )
        VALUES
            (
            #{empId},
            #{authorityCode}
             )
    </insert>

    <!-- ════════════════════════════════════════
         [6-1] employee1 수정 — 비밀번호, 권한, 상태 등
               비밀번호는 null 이면 수정하지 않음
    ════════════════════════════════════════ -->
    <update id="updateEmployee1" parameterType="com.mvc.app.domain.dto.HrmDto">
        UPDATE employee1
        SET
            updateDate = SYSDATE
            <if test="password      != null and password      != ''">, password      = #{password}      </if>
            <if test="levelCode     != null">                         , levelCode     = #{levelCode}     </if>
            <if test="enabled       != null">                         , enabled       = #{enabled}       </if>
            <if test="empStatusCode != null and empStatusCode != ''">, empStatusCode = #{empStatusCode} </if>
        WHERE empId = #{empId}
    </update>

    <!-- ════════════════════════════════════════
         [6-2] employee2 수정 — 이름, 부서, 직급 등
               사원번호(empId)는 수정 불가
    ════════════════════════════════════════ -->
    <update id="updateEmployee2" parameterType="com.mvc.app.domain.dto.HrmDto">
        UPDATE employee2
        SET
            name        = #{name}
            <if test="birth       != null and birth       != ''">, birth       = #{birth}       </if>
            <if test="profilePhoto!= null">                       , profilePhoto= #{profilePhoto}</if>
            <if test="tel         != null">                       , tel         = #{tel}         </if>
            <if test="zip         != null">                       , zip         = #{zip}         </if>
            <if test="addr1       != null">                       , addr1       = #{addr1}       </if>
            <if test="addr2       != null">                       , addr2       = #{addr2}       </if>
            <if test="email       != null">                       , email       = #{email}       </if>
            <if test="hireDate    != null and hireDate    != ''">, hireDate    = #{hireDate}    </if>
            <if test="deptCode    != null">                       , deptCode    = #{deptCode}    </if>
            <if test="gradeCode   != null">                       , gradeCode   = #{gradeCode}   </if>
        WHERE empId = #{empId}
    </update>
    
    <update id="updateAuthority" parameterType="com.mvc.app.domain.dto.HrmDto">
        UPDATE employeeAuthority
        SET authority = #{authorityCode}
        WHERE empId = #{empId}
    </update>

    <!-- ════════════════════════════════════════
         [7] 단건 탈퇴 — employee1 drawCode 탈퇴여부 'y' 처리
    ════════════════════════════════════════ -->
    <update id="deleteEmployee1" parameterType="string">
        UPDATE employee1 SET drawCode = 'y' WHERE empId = #{empId}
    </update>

    <!-- ════════════════════════════════════════
         [8] 벌크 삭제 — employee1 drawCode 탈퇴여부 'y' 처리
    ════════════════════════════════════════ -->
    <update id="deleteEmployees1" parameterType="list">
        UPDATE employee1 SET drawCode = 'y'
        WHERE empId IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- ════════════════════════════════════════
         [9] 공통코드 조회 — codeGroup 별 code/codename 목록
         반환 Map 키: code, codeName
    ════════════════════════════════════════ -->
    <select id="listCommonCode" parameterType="string" resultType="map">
        SELECT code, codename AS codeName
        FROM   commoncode
        WHERE  codegroup = #{codeGroup}
        ORDER BY code
    </select>

</mapper>